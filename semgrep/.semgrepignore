# =============================================================================
# .semgrepignore - Exclude paths from Semgrep scanning
# =============================================================================

# ==== Common ====
# IDE files
.idea/
.vscode/
*.iml

# Config & docs
*.md
*.txt
LICENSE

# ==== Java/Spring Boot ====
# Build artifacts & dependencies
target/
build/
.gradle/
.mvn/
node_modules/

# Generated code (Lombok, MapStruct, etc.)
**/generated/**
**/generated-sources/**
**/generated-test-sources/**

# Test files (less strict scanning - handled separately)
**/src/test/**

# Static resources
**/src/main/resources/static/**
**/src/main/resources/templates/**

# Load test scripts
loadtests/

# ==== Go ====
# Dependencies (vendored)
vendor/

# Generated code (protobuf, mockgen, etc.)
**/mock_*.go
**/mocks/
**/*.pb.go
**/*_generated.go

# Test fixtures & testdata
**/testdata/
**/testfixtures/

# Build output
bin/
dist/
